{
  "name": "@kinvue/contracts",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "proto"
  ],
  "scripts": {
    "generate": "node -e \"require('fs').mkdirSync('src/generated',{recursive:true})\" && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=.\\node_modules\\.bin\\protoc-gen-ts_proto.cmd --ts_proto_out=./src/generated --ts_proto_opt=nestJs=true,outputServices=grpc-js,useOptionals=messages --proto_path=./proto ./proto/auth.proto",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "grpc-tools": "^1.13.1",
    "protobufjs": "^8.7.1",
    "ts-proto": "^2.12.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@grpc/grpc-js": "^1.14.4",
    "@nestjs/microservices": "^11.1.28",
    "rxjs": "^7.8.2"
  }
}