{
  "name": "KinVue_Server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:gateway" : "pnpm  --filter @kinvue/gateway run start:dev",
    "lint": "eslint .",
    "lint:fix" : "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },

  "packageManager": "pnpm@10.34.4",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  }
}
